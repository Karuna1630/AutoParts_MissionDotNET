# Database Configuration
CONNECTION_STRING=Host=localhost;Port=5432;Database=AutoParts;Username=postgres;Password=YOUR_PASSWORD

# JWT Configuration
JWT_KEY=YOUR_SECURE_KEY_MIN_32_CHARS
JWT_ISSUER=VehiclePartsAPI
JWT_AUDIENCE=VehiclePartsClients

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Seed
ADMIN_EMAIL=admin@autoparts.com
ADMIN_PASSWORD=AdminPassword123!
